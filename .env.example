# AI API配置示例
# 复制此文件为 .env 并填入真实配置

# AI API类型：mock (模拟), zhipu (智谱AI), qwen (通义千问), freetheai (FreeTheAI)
AI_API_TYPE=freetheai

# FreeTheAI配置 (推荐，可免费使用多个模型)
# 访问 https://freetheai.xyz 获取免费API Key
AI_API_KEY=your_freetheai_api_key_here
AI_MODEL=or/openai/gpt-oss-20b:free
# 可选模型（根据FreeTheAI官方文档）：
# - or/openai/gpt-oss-20b:free (免费，推荐)
# - kai/* (Kai模型组)
# - opc/* (OPC模型组)
# - or/* (OR模型组)
# 获取完整模型列表：GET https://api.freetheai.xyz/v1/models
AI_BASE_URL=https://api.freetheai.xyz/v1

# =============================================
# 如何获取免费API密钥
# =============================================
#
# 1. FreeTheAI (推荐，完全免费)
#    - 访问: https://freetheai.xyz
#    - 加入 Discord 服务器
#    - 运行 /signup 命令获取API密钥
#    - 每天需要运行 /checkin 签到
#    - 配置示例:
#      AI_API_TYPE=freetheai
#      AI_API_KEY=your_freetheai_key_here
#      AI_MODEL=or/openai/gpt-oss-20b:free
#      AI_BASE_URL=https://api.freetheai.xyz/v1
#
# 2. Mock (默认，无需API密钥)
#    - 使用本地规则引擎，不调用外部API
#    - 配置示例:
#      AI_API_TYPE=mock
#
# =============================================
